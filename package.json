{
  "name": "kick-accounting",
  "version": "1.0.0",
  "description": "Backend accounting platform with General Ledger and financial reports",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "docker compose -f docker-compose.test.yml up -d --wait && DB_PORT=5433 DB_NAME=accounting_test DB_PASSWORD=testpassword vitest run tests/integration/ ; docker compose -f docker-compose.test.yml down",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "load": "tsx scripts/load.ts"
  },
  "dependencies": {
    "big.js": "^7.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^171.4.0",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.3",
    "tsx": "^4.19.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "eslint": "^8.57.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
